PORT=3000

# ── Firebase Firestore（未設定時は data/*.json にフォールバック）
# 方法A: 個別の環境変数（Railway推奨）
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
#
# 方法B: サービスアカウントJSONをそのまま文字列に
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}

# ── 管理画面パスワード
ADMIN_PASSWORD_SUPER=your_super_admin_password
ADMIN_PASSWORD_STORE=your_store_admin_password

# Google Calendar API (optional)
# 1. Go to https://console.cloud.google.com/
# 2. Create a project and enable Google Calendar API
# 3. Create OAuth2 credentials
# 4. Fill in the values below and rename this file to .env

GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google-calendar/callback
SESSION_SECRET=change_this_to_a_random_string
