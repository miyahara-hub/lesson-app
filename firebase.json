{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.git/**",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "app",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": ".",
    "runtime": "nodejs18",
    "ignore": [
      "node_modules",
      ".git",
      "*.log",
      "data",
      "public",
      "firebase-key.json",
      ".env",
      ".env.*"
    ]
  }
}
