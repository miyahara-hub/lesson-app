{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.git/**",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "app"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": ".",
    "runtime": "nodejs18",
    "ignore": [
      "node_modules",
      ".git",
      "*.log",
      "data",
      "public"
    ]
  }
}
